CARDHOLDER_NAME=YOUR NAME

# WealthSimple account mappings: WS_ACCOUNT_<AccountNo>=<Source>
# Maps account numbers to human-readable source labels.
# Account names become "WS <Source>-<AccountNo>" (e.g. "WS Cash-XXXXXXXXXXXX").
# Unmapped accounts fall back to "WS <AccountNo>".
# WS_ACCOUNT_XXXXXXXXXXXX=Crypto
# WS_ACCOUNT_YYYYYYYYYYYY=Cash
